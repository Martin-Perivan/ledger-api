{
  "info": {
    "name": "Ledger API",
    "description": "Double-entry accounting engine for digital wallets with AI-powered fraud detection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "accountId", "value": "" },
    { "key": "recipientAccountId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"MinLength8!\",\n  \"fullName\": \"José Martín\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('userId', data.userId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"MinLength8!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('accessToken', data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Create Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/accounts", "host": ["{{baseUrl}}"], "path": ["accounts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currency\": \"MXN\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('accountId', data.accountId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Accounts",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/accounts", "host": ["{{baseUrl}}"], "path": ["accounts"] }
          }
        },
        {
          "name": "Get Account Detail",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/accounts/{{accountId}}", "host": ["{{baseUrl}}"], "path": ["accounts", "{{accountId}}"] }
          }
        },
        {
          "name": "Get Account History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/accounts/{{accountId}}/history?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["accounts", "{{accountId}}", "history"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Deposits",
      "item": [
        {
          "name": "Create Deposit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "url": { "raw": "{{baseUrl}}/deposits", "host": ["{{baseUrl}}"], "path": ["deposits"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"amount\": 50000,\n  \"currency\": \"MXN\",\n  \"description\": \"Initial funding\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Transfers",
      "item": [
        {
          "name": "Create Transfer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "url": { "raw": "{{baseUrl}}/transfers", "host": ["{{baseUrl}}"], "path": ["transfers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountId\": \"{{accountId}}\",\n  \"toAccountId\": \"{{recipientAccountId}}\",\n  \"amount\": 10000,\n  \"currency\": \"MXN\",\n  \"description\": \"Payment for dinner\"\n}"
            }
          }
        }
      ]
    }
  ]
}
